# Normalize line endings to LF in the repository (consistent across Windows/Linux)
* text=auto eol=lf

*.go     text eol=lf
*.sql    text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.json   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.md     text eol=lf
Makefile text eol=lf

# Binary assets — do not touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
