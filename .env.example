# GoAcademy — пример переменных окружения.
# Скопируйте в .env (`cp .env.example .env`) и заполните секреты. .env в .gitignore.
# Колонка "С этапа" показывает, когда переменная начинает использоваться.
# Значения по умолчанию совпадают с defaults в deploy/docker-compose.yml.

# ============================================================
# PostgreSQL  (STAGE 0.3)  — используется docker-compose и backend
# ============================================================
POSTGRES_VERSION=17
POSTGRES_USER=goacademy
POSTGRES_PASSWORD=goacademy_dev_password   # ОБЯЗАТЕЛЬНО сменить вне локалки
POSTGRES_DB=goacademy
POSTGRES_PORT=5432                          # порт на хосте (маппинг на 5432 в контейнере)

# Строка подключения для backend (CHAPTER 1.3).
# Локально из хоста: host=localhost; из контейнера backend: host=postgres.
DATABASE_URL=postgres://goacademy:goacademy_dev_password@localhost:5432/goacademy?sslmode=disable

# ============================================================
# Backend / HTTP  (CHAPTER 1)
# ============================================================
APP_ENV=development            # development | production
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
LOG_LEVEL=debug                # debug | info | warn | error
LOG_FORMAT=text                # text | json  (в production — json)

# ============================================================
# Аутентификация / JWT  (CHAPTER 2)
# ============================================================
JWT_SECRET=change_me_dev_secret_at_least_32_chars   # ОБЯЗАТЕЛЬНО задать свой секрет
JWT_ACCESS_TTL=15m             # время жизни access-токена
JWT_REFRESH_TTL=720h           # время жизни refresh-токена (30 дней)
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false            # true в production (HTTPS)
COOKIE_SAMESITE=lax            # lax | strict | none

# CORS — разрешённые источники фронтенда (через запятую)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ============================================================
# Mailer  (CHAPTER 2)  — на старте заглушка (логирует токены), SMTP позже
# ============================================================
MAILER_DRIVER=log              # log | smtp (smtp — поздняя фаза)
MAIL_FROM=no-reply@goacademy.local
EMAIL_VERIFICATION_TTL=24h     # срок жизни токена верификации email (Go-duration: 24h, 30m, ...)
PASSWORD_RESET_TTL=1h          # срок жизни токена сброса пароля
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=

# ============================================================
# Хранилище файлов / аватары  (CHAPTER 3, решение D-009)
# ============================================================
STORAGE_DRIVER=local           # local | s3 (s3 — поздняя фаза)
STORAGE_LOCAL_DIR=./storage    # относительно cwd backend (т.е. backend/storage); в .gitignore
STORAGE_PUBLIC_BASE_URL=http://localhost:8080/static

# ============================================================
# Rate limiting  (CHAPTER 2.4)
# ============================================================
RATE_LIMIT_AUTH_PER_MINUTE=10

# ============================================================
# Code sandbox  (CHAPTER 16) — opt-in; needs Docker + a Go toolchain on the host
# ============================================================
SANDBOX_ENABLED=false              # true to mount POST /api/v1/sandbox/run
SANDBOX_IMAGE=busybox              # minimal image to run the static binary in
SANDBOX_WORK_DIR=                  # host dir for transient build dirs (empty = OS temp)
RATE_LIMIT_SANDBOX_PER_MINUTE=6    # per-IP budget for sandbox runs

# ============================================================
# Frontend  (CHAPTER 14)
# ============================================================
VITE_API_BASE_URL=http://localhost:8080/api/v1

# ============================================================
# Code runner  (CHAPTER 16)
# ============================================================
# RUNNER_URL=http://code-runner:9090
# RUNNER_TIMEOUT=5s
# RUNNER_MAX_OUTPUT_BYTES=65536
